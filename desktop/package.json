{
    "name": "ccb-desktop",
    "version": "0.1.0",
    "description": "Claude Code Bridge Desktop — Multi-Model AI Collaboration Client",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "lint": "eslint .",
        "pack": "electron-vite build && electron-builder --dir",
        "dist": "electron-vite build && electron-builder",
        "dist:mac": "electron-vite build && electron-builder --mac",
        "dist:win": "electron-vite build && electron-builder --win",
        "dist:linux": "electron-vite build && electron-builder --linux"
    },
    "build": {
        "appId": "com.ccb.desktop",
        "productName": "CCB Desktop",
        "directories": {
            "output": "release"
        },
        "icon": "resources/icon",
        "asar": true,
        "asarUnpack": [
            "node_modules/node-pty/**"
        ],
        "files": [
            "out/**/*"
        ],
        "extraResources": [
            {
                "from": "../bin/",
                "to": "ccb/bin",
                "filter": [
                    "**/*",
                    "!*.cmd"
                ]
            },
            {
                "from": "../lib/",
                "to": "ccb/lib",
                "filter": [
                    "**/*.py",
                    "**/*.json",
                    "**/*.html",
                    "**/*.css",
                    "**/*.js",
                    "!__pycache__/**"
                ]
            }
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "darkModeSupport": true,
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "dmg": {
            "title": "CCB Desktop ${version}",
            "artifactName": "CCB-Desktop-${version}-${arch}.dmg"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "artifactName": "CCB-Desktop-${version}-win.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Development",
            "artifactName": "CCB-Desktop-${version}-linux.${ext}"
        },
        "protocols": [
            {
                "name": "CCB Desktop",
                "schemes": [
                    "ccb"
                ]
            }
        ],
        "publish": [
            {
                "provider": "github",
                "owner": "ccb",
                "repo": "ccb-desktop"
            }
        ]
    },
    "dependencies": {
        "@electron-toolkit/utils": "^3.0.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-search": "^0.16.0",
        "@xterm/addon-web-links": "^0.12.0",
        "@xterm/xterm": "^6.0.0",
        "highlight.js": "^11.11.1",
        "i18next": "^24.2.0",
        "node-pty": "^1.1.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-i18next": "^15.4.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.1.0",
        "rehype-highlight": "^7.0.2",
        "remark-gfm": "^4.0.1",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "electron": "^35.1.4",
        "electron-builder": "^26.8.1",
        "electron-vite": "^3.0.0",
        "eslint": "^9.0.0",
        "tailwindcss": "^4.0.0"
    }
}